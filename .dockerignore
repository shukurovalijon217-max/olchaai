# Large asset dirs that are not needed in Docker build
attached_assets/
.cache/
.local/

# Build outputs
**/dist
**/.tsbuildinfo
**/node_modules

# Dev/test artifacts
**/*.test.ts
**/*.spec.ts
**/.local
**/.agents

# Logs & temp
**/*.log
**/tmp

# Git
.git
.gitignore

# Artifacts not needed for Nexus or API builds
artifacts/olcha-mobile
artifacts/spatial-ar
artifacts/ai-core
artifacts/olcha-go
artifacts/mockup-sandbox

# Lib packages not needed for Nexus build
lib/api-spec
lib/integrations
lib/object-storage-web
