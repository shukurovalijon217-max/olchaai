modules = ["nodejs-24", "go-1.25", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/olcha-go: Go Real-Time Service"

[[workflows.workflow]]
name = "artifacts/olcha-go: Go Real-Time Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/olcha-go && PORT=8099 DATABASE_URL=$DATABASE_URL ./bin/olcha-go"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 18245
externalPort = 3000

[[ports]]
localPort = 18348
externalPort = 3002

[[ports]]
localPort = 18349
externalPort = 4200

[[ports]]
localPort = 23681
externalPort = 5000

